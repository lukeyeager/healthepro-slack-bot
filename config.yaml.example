org_id: 0      # Health-e Pro organization ID
menu_id: 0     # Health-e Pro menu ID
fetch_cron: "0 * * * *"            # hourly fetch (default)
db_path: "/data/menus.db"          # inside container; bind-mount ./data/ from host
timezone: "America/Chicago"        # week boundary and display timezone
http_addr: ":8080"                 # serves / (menu page) and /metrics (Prometheus)
